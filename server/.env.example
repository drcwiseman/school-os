PORT=5000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/school_os
SESSION_SECRET=your-randomly-generated-session-secret-here

# Production: public app URL for CORS (e.g. https://app.yourschool.com)
CLIENT_ORIGIN=

# Subdomain / custom domain routing (production)
USE_SUBDOMAIN=false
PLATFORM_DOMAIN=school.bclimaxtech.com
INGRESS_CNAME_TARGET=school.bclimaxtech.com
INGRESS_IP=173.231.241.161

# Messaging (optional platform-wide SMS stub)
MESSAGING_PROVIDER=console
MESSAGING_API_KEY=

# Per-school SMTP is configured in Settings when the custom_smtp plan feature is enabled.

# Platform operator emails (invites, password resets)
PLATFORM_SMTP_HOST=
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_SECURE=false
PLATFORM_SMTP_USER=
PLATFORM_SMTP_PASS=
PLATFORM_SMTP_FROM=
PLATFORM_SMTP_FROM_NAME=SchoolOS Platform
