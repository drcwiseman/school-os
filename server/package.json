{
  "name": "school-os-server",
  "version": "1.0.0",
  "description": "Multi-Tenant School Management System Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:seed": "ts-node src/db/seed.ts",
    "db:ensure-platform": "ts-node scripts/ensure-platform-admin.ts",
    "db:repair": "ts-node scripts/repair-vps-schema.ts",
    "db:doctor": "ts-node scripts/db-doctor.ts",
    "db:build-full-migration": "ts-node scripts/build-full-migration.ts",
    "db:up": "node scripts/embedded-pg.mjs",
    "dev:setup": "ts-node scripts/wait-for-pg.ts && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "date-fns": "^4.2.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.21.4",
    "embedded-postgres": "^18.3.0-beta.17",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "embedded-postgres": "^3.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
